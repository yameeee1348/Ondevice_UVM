CommandSyntax.finsim\AbsTimeBreak=\"break abstimeaf ${SimBPTime}\"
CommandSyntax.finsim\DeleteAllBP=\"breakclr\"
CommandSyntax.finsim\DeleteBP=\"breakclr ${SimBPId}\"
CommandSyntax.finsim\DisableBP=\"breakoff ${SimBPId}\"
CommandSyntax.finsim\EnableBP=\"breakon ${SimBPId}\"
CommandSyntax.finsim\Finish=\"quit\"
CommandSyntax.finsim\FullFileName=true
CommandSyntax.finsim\HierNameLevel=1
CommandSyntax.finsim\InvokeCommand=
CommandSyntax.finsim\LineBreak=\"breakline ${SimBPFile} ${SimBPLine}\"
CommandSyntax.finsim\NextEvent=\"run 1\"
CommandSyntax.finsim\NextNTime=\"run ${SimBPTime}\"
CommandSyntax.finsim\NextTime=\"run 1\"
CommandSyntax.finsim\ObjAnyBreak=\"break change ${SimBPObj}\"
CommandSyntax.finsim\ObjLevelBreak=
CommandSyntax.finsim\ObjNegBreak=\"break negedge ${SimBPObj}\"
CommandSyntax.finsim\ObjPosBreak=\"break posedge ${SimBPObj}\"
CommandSyntax.finsim\RelTimeBreak=\"break reltimeaf ${SimBPTime}\"
CommandSyntax.finsim\Reset=
CommandSyntax.finsim\RunContinue=\"continue\"
CommandSyntax.finsim\Separator=.
CommandSyntax.finsim\SimPromptSign=\">\"
CommandSyntax.finsim\SimSetScope=\"cd ${SimDmpObj}\"
CommandSyntax.finsim\UseAbsTime=false
CommandSyntax.ikos\AbsTimeBreak=
CommandSyntax.ikos\DeleteAllBP=\"delete *\"
CommandSyntax.ikos\DeleteBP=\"delete ${SimBPId}\"
CommandSyntax.ikos\DisableBP=\"disable ${SimBPId}\"
CommandSyntax.ikos\EnableBP=\"enable ${SimBPId}\"
CommandSyntax.ikos\Finish=\"exit\"
CommandSyntax.ikos\FullFileName=true
CommandSyntax.ikos\HierNameLevel=2
CommandSyntax.ikos\InvokeCommand="\"setvar debussy true;elaborate -p ${SimTop} -s ${SimArch}; run until 0;fsdbInteractive; \""
CommandSyntax.ikos\LineBreak=\"stop at ${SimBPFile}:${SimBPLine}\"
CommandSyntax.ikos\NeedTimeUnit=true
CommandSyntax.ikos\NextEvent=\"step 1\"
CommandSyntax.ikos\NextNTime=\"run for ${SimBPTime} ${SimTimeUnit}\"
CommandSyntax.ikos\NextTime=\"run ${SimBPTime} ${SimTimeUnit}\"
CommandSyntax.ikos\NormalizeTimeUnit=true
CommandSyntax.ikos\ObjAnyBreak=
CommandSyntax.ikos\ObjLevelBreak="\"stop if ${SimBPObj} = ${SimBPValue}\""
CommandSyntax.ikos\ObjNegBreak="\"stop if ${SimBPObj} = \\\"'0'\\\"\""
CommandSyntax.ikos\ObjPosBreak="\"stop if ${SimBPObj} = \\\"'1'\\\"\""
CommandSyntax.ikos\RelTimeBreak=
CommandSyntax.ikos\Reset=\"reset\"
CommandSyntax.ikos\RunContinue=\"run\"
CommandSyntax.ikos\Separator=/
CommandSyntax.verisity\AbsTimeBreak="\"$db_breakbeforetime(${SimBPTime});\""
CommandSyntax.verisity\DeleteAllBP="\"$db_deletebreak;\""
CommandSyntax.verisity\DeleteBP="\"$db_deletebreak(${SimBPId});\""
CommandSyntax.verisity\DisableBP="\"$db_disablebreak(${SimBPId});\""
CommandSyntax.verisity\EnableBP="\"$db_enablebreak(${SimBPId});\""
CommandSyntax.verisity\FSDBDumpMem="\"$novasDumpMemNow(${SimDmpObj}, ${SimDmpBegin}, ${SimDmpSize});\""
CommandSyntax.verisity\FSDBDumpsingle="\"$novasDumpsingle(${SimDmpObj});\""
CommandSyntax.verisity\FSDBDumpvars="\"$novasDumpvars(0, ${SimDmpObj});\""
CommandSyntax.verisity\FSDBDumpvarsInFile="\"$novasDumpvarsToFile(\\\"${SimDmpFile}\\\");\""
CommandSyntax.verisity\FSDBInit="\"$novasInteractive;\""
CommandSyntax.verisity\Finish="\"$finish;\""
CommandSyntax.verisity\FullFileName=false
CommandSyntax.verisity\HierNameLevel=1
CommandSyntax.verisity\InvokeCommand=
CommandSyntax.verisity\LineBreak="\"$db_breakatline(${SimBPLine}, ${SimBPScope}, \\\"${SimBPFile}\\\");\""
CommandSyntax.verisity\NextEvent="\"$db_step;\""
CommandSyntax.verisity\NextNTime="\"$db_steptime(${SimBPTime});\""
CommandSyntax.verisity\NextTime="\"$db_steptime(1);\""
CommandSyntax.verisity\ObjAnyBreak="\"$db_breakwhen(${SimBPObj});\""
CommandSyntax.verisity\ObjLevelBreak="\"$db_breakwhen(${SimBPObj}, ${SimBPValue});\""
